flowchart LR

  %% Data sources
  RAW[(Raw SMS corpus)]
  CFG[[config.json + best_hyperparameters.json]]

  %% Notebooks
  N1["1-eda-1.ipynb\nInitial corpus exploration"]
  N2["2-preprocess-lstm.ipynb\nCleaning + train/val/test split"]
  N3["3-eda-2.ipynb\nPost-cleaning EDA"]
  N4["4-tokenization.ipynb\nSentencePiece training + token checks"]
  N5["5-eda-3.ipynb\nFinal EDA / distribution validation"]

  %% Artifacts
  TRAIN[(train_processed.csv)]
  VAL[(validation_processed.csv)]
  TEST[(test_processed.csv)]
  TOK[(lstm_tokenizer.model)]
  MODEL[(best_model.pt / checkpoints)]
  METRICS[(evaluation metrics JSON)]
  FIGS[(plots for thesis)]

  %% Flow
  RAW --> N1
  N1 --> N2
  N2 --> TRAIN
  N2 --> VAL
  N2 --> TEST

  TRAIN --> N3
  VAL --> N3
  TEST --> N3

  TRAIN --> N4
  N4 --> TOK

  TRAIN --> N5
  VAL --> N5
  TEST --> N5

  %% Connection to code pipeline (outside notebooks)
  CFG --> MODEL
  TOK --> MODEL
  TRAIN --> MODEL
  VAL --> MODEL

  MODEL --> METRICS
  TEST --> METRICS
  N3 --> FIGS
  N5 --> FIGS
